generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String    @id @default(uuid())
  name         String
  email        String    @unique
  passwordHash String
  role         Role      @default(STUDENT)
  level        Int       @default(1)
  xpTotal      Int       @default(0)
  streakDays   Int       @default(0)
  lastActiveAt DateTime?
  createdAt    DateTime  @default(now())

  gameSessions     GameSession[]
  masteryScores    MasteryScore[]
  tests            Test[]
  studyPlans       StudyPlan[]
  domainProgress   UserDomainProgress[]
  userAchievements UserAchievement[]
  interviewProgress UserInterviewProgress[]
  testAttempts     TestAttempt[]
  aiInterviews     AiInterview[]
  createdTests     AssessmentTest[] @relation("CreatedTests")
}

enum Role {
  STUDENT
  COLLEGE_STUDENT
  EDUCATOR
  ADMIN
}

// Topics define the taxonomy Claude uses to generate questions.
// They do NOT hold questions — they are navigation nodes only.
model Topic {
  id        String   @id @default(uuid())
  subject   String   // e.g. "Physics"
  topic     String   // e.g. "Thermodynamics"
  subtopic  String   // e.g. "Carnot cycle"  ← this is what Claude receives
  isActive  Boolean  @default(true)
  domainId  String?
  domain    Domain?  @relation(fields: [domainId], references: [id])
  levelOrder Int     @default(1)    // 1=beginner, 2, 3... higher=harder
  createdAt DateTime @default(now())

  gameSessions  GameSession[]
  masteryScores MasteryScore[]
  studyPlans    StudyPlan[]
}

// Stores session metadata only. No question content.
model GameSession {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  topicId     String
  topic       Topic    @relation(fields: [topicId], references: [id])
  gameType    GameType @default(MCQ)
  difficulty  Int      @default(2)
  score       Int      @default(0)
  xpEarned    Int      @default(0)
  durationSec Int      @default(0)
  playedAt    DateTime @default(now())

  attempts QuestionAttempt[]
}

enum GameType {
  MCQ
  MEMORY_MATCH
  WORD_SCRAMBLE
  CROSSWORD
  HANGMAN
  FILL_BLANK
  CONCEPT_CANNON
}

// Stores per-question result without storing the question itself.
// questionHash = sha256(questionText).slice(0,16) — deterministic, reproducible.
model QuestionAttempt {
  id           String      @id @default(uuid())
  sessionId    String
  session      GameSession @relation(fields: [sessionId], references: [id])
  questionHash String      // identifies the question without storing it
  subtopic     String      // copied from topic for fast mastery queries
  difficulty   Int
  isCorrect    Boolean
  timeTakenMs  Int
  hintUsed     Boolean     @default(false)
}

model MasteryScore {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  topicId      String
  topic        Topic    @relation(fields: [topicId], references: [id])
  score        Float    @default(0)
  isWeak       Boolean  @default(false)
  attemptCount Int      @default(0)
  nextReviewAt DateTime?
  lastUpdated  DateTime @default(now())

  @@unique([userId, topicId])
}

model Test {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  testType    String   @default("mixed")
  subject     String
  totalMarks  Int
  scoredMarks Int
  timeLimitMin Int     @default(30)
  questionCount Int    @default(30)
  takenAt     DateTime @default(now())

  testQuestions TestQuestion[]
}

// Test questions are also AI-generated. Store result only.
model TestQuestion {
  id           String  @id @default(uuid())
  testId       String
  test         Test    @relation(fields: [testId], references: [id])
  questionHash String
  subtopic     String  // critical — weakness detection reads this
  topicArea    String  @default("aptitude")
  difficulty   Int
  isCorrect    Boolean
  marksAwarded Int     @default(0)
}

model StudyPlan {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  topicId     String
  topic       Topic    @relation(fields: [topicId], references: [id])
  priority    Priority @default(MEDIUM)
  isCompleted Boolean  @default(false)
  dueDate     DateTime?
  createdAt   DateTime @default(now())

  @@unique([userId, topicId])
}

enum Priority {
  HIGH
  MEDIUM
  LOW
}

model Domain {
  id          String   @id @default(uuid())
  slug        String   @unique
  name        String
  icon        String
  description String
  color       String
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  topics       Topic[]
  userProgress UserDomainProgress[]
}

model UserDomainProgress {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  domainId        String
  domain          Domain   @relation(fields: [domainId], references: [id])
  currentLevel    Int      @default(1)
  totalXpInDomain Int      @default(0)
  rank            String   @default("Bronze Coder")
  updatedAt       DateTime @updatedAt

  @@unique([userId, domainId])
}

model Achievement {
  id          String   @id @default(uuid())
  slug        String   @unique
  name        String
  description String
  icon        String
  category    String
  xpReward    Int      @default(0)
  condition   String
  createdAt   DateTime @default(now())

  userAchievements UserAchievement[]
}

model UserAchievement {
  id            String      @id @default(uuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id])
  achievementId String
  achievement   Achievement @relation(fields: [achievementId], references: [id])
  earnedAt      DateTime    @default(now())

  @@unique([userId, achievementId])
}

// ===== INTERVIEW PREP MODELS =====

model InterviewCategory {
  id          String   @id @default(uuid())
  section     String   // "A", "B", "C"
  name        String   // "Quantitative Aptitude", "Logical Reasoning", "Verbal Ability"
  slug        String   @unique // "quantitative-aptitude", "logical-reasoning", "verbal-ability"
  icon        String   // emoji
  description String
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  topics    InterviewTopic[]
}

model InterviewTopic {
  id          String   @id @default(uuid())
  name        String   // "Number System", "Percentages", "Calendars", etc.
  slug        String   // "number-system"
  categoryId  String
  category    InterviewCategory @relation(fields: [categoryId], references: [id])
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  questions   InterviewQuestion[]
  theory      InterviewTheory?
  progress    UserInterviewProgress[]

  @@unique([categoryId, slug])
}

model InterviewQuestion {
  id              String   @id @default(uuid())
  topicId         String
  topic           InterviewTopic @relation(fields: [topicId], references: [id])
  questionNumber  Int
  question        String
  optionA         String
  optionB         String
  optionC         String
  optionD         String
  optionE         String?
  correctAnswer   String   // "A", "B", "C", "D" — from solved JSON
  correctIndex    Int      // 0-indexed — from solved JSON
  difficulty      String   @default("medium") // easy, medium, hard
  sourceRef       String?  // "The Aptitude Triad"
  createdAt       DateTime @default(now())
}

model InterviewTheory {
  id              String   @id @default(uuid())
  topicId         String   @unique
  topic           InterviewTopic @relation(fields: [topicId], references: [id])
  rawTheory       String   // full theory text from JSON
  keyPoints       Json     // string[] from quick_notes.keyPoints
  formulas        Json     // string[] from quick_notes.formulas
  tutorialSections Json    // [{heading, content}] from tutorial_sections
  formulaCount    Int      @default(0)
  exampleCount    Int      @default(0)
  conceptCount    Int      @default(0)
  cleanedAt       DateTime?
}

model UserInterviewProgress {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  topicId     String
  topic       InterviewTopic @relation(fields: [topicId], references: [id])
  gamesPlayed Int      @default(0)
  bestScore   Int      @default(0)
  avgScore    Float    @default(0)
  totalXp     Int      @default(0)
  lastPlayedAt DateTime?

  @@unique([userId, topicId])
}

// ===== ASSESSMENT PLATFORM (proctored tests + AI interview) =====
// Named Assessment* to avoid collision with the legacy Topic/Test/Question
// models above, which belong to the game arcade and store results only.

enum AssessmentCategory {
  QUANTITATIVE
  LOGICAL
  VERBAL
  CODING
}

enum AssessmentQuestionType {
  SINGLE
  MULTI
  FILL
  TRUE_FALSE
}

enum AssessmentDifficulty {
  EASY
  MEDIUM
  HARD
}

enum AssessmentTestMode {
  PRACTICE
  PROCTORED
}

enum AssessmentTestStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum TestSectionKind {
  APTITUDE
  VERBAL
  LOGICAL
  CODING
  MIXED
}

enum AttemptStatus {
  IN_PROGRESS
  SUBMITTED
  EXPIRED
}

enum ProctoringEventType {
  TAB_BLUR
  TAB_FOCUS
  FULLSCREEN_EXIT
  COPY
  PASTE
  FACE_NOT_DETECTED
  MULTIPLE_FACES
  NO_CAMERA
  SNAPSHOT
}

enum AiInterviewStatus {
  IN_PROGRESS
  COMPLETED
  ABANDONED
}

enum AiInterviewTurnRole {
  INTERVIEWER
  CANDIDATE
}

model AssessmentTopic {
  id        String             @id @default(uuid())
  name      String
  slug      String             @unique
  category  AssessmentCategory
  parentId  String?
  parent    AssessmentTopic?   @relation("AssessmentTopicTree", fields: [parentId], references: [id])
  children  AssessmentTopic[]  @relation("AssessmentTopicTree")
  order     Int                @default(0)
  createdAt DateTime           @default(now())

  questions      AssessmentQuestion[]
  codingProblems CodingProblem[]
}

model AssessmentQuestion {
  id             String                 @id @default(uuid())
  topicId        String
  topic          AssessmentTopic        @relation(fields: [topicId], references: [id])
  type           AssessmentQuestionType @default(SINGLE)
  difficulty     AssessmentDifficulty   @default(MEDIUM)
  stem           String // markdown
  assets         Json? // images/tables/figures; assets.requiresImage = true for figure-based items
  explanation    String? // worked solution (from solve-and-verify or human)
  proposedAnswer String? // option letter proposed by AI solver, pending human confirmation
  source         String?
  sourceUrl      String?
  verified       Boolean                @default(false)
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  options      AssessmentOption[]
  sectionItems TestSectionItem[]
  responses    AttemptResponse[]
}

model AssessmentOption {
  id         String             @id @default(uuid())
  questionId String
  question   AssessmentQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  text       String
  isCorrect  Boolean            @default(false)
  order      Int                @default(0)
}

model CodingProblem {
  id                String               @id @default(uuid())
  topicId           String
  topic             AssessmentTopic      @relation(fields: [topicId], references: [id])
  title             String
  slug              String               @unique
  statement         String // markdown — our own restated statement, never scraped text
  difficulty        AssessmentDifficulty @default(MEDIUM)
  constraints       String?
  sampleIo          Json? // [{ input, output, explanation? }]
  starterCode       Json? // keyed by language: { cpp, java, python, javascript }
  referenceSolution Json? // keyed by language
  timeLimitMs       Int                  @default(2000)
  memoryLimitMb     Int                  @default(256)
  source            String?
  sourceUrl         String? // attribution link (e.g. A2Z sheet item)
  verified          Boolean              @default(false) // true once reference solution passes all test cases
  createdAt         DateTime             @default(now())

  testCases    TestCase[]
  sectionItems TestSectionItem[]
  responses    AttemptResponse[]
}

model TestCase {
  id              String        @id @default(uuid())
  codingProblemId String
  codingProblem   CodingProblem @relation(fields: [codingProblemId], references: [id], onDelete: Cascade)
  input           String
  expectedOutput  String
  isSample        Boolean       @default(false)
  weight          Int           @default(1)
}

model Company {
  id      String  @id @default(uuid())
  name    String
  slug    String  @unique
  logoUrl String?
  notes   String?
  profile Json? // pattern profile: topic weights, difficulty mix, round structure, interview style

  tests      AssessmentTest[]
  interviews AiInterview[]
}

model AssessmentTest {
  id              String               @id @default(uuid())
  title           String
  description     String?
  durationMinutes Int                  @default(90) // free integer; UI offers 90 / 180 presets
  mode            AssessmentTestMode   @default(PRACTICE)
  companyId       String?
  company         Company?             @relation(fields: [companyId], references: [id])
  randomizeOrder  Boolean              @default(false)
  negativeMarking Float                @default(0) // marks deducted per wrong answer
  passScore       Int?
  createdById     String?
  createdBy       User?                @relation("CreatedTests", fields: [createdById], references: [id])
  status          AssessmentTestStatus @default(DRAFT)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  sections TestSection[]
  attempts TestAttempt[]
}

model TestSection {
  id               String          @id @default(uuid())
  testId           String
  test             AssessmentTest  @relation(fields: [testId], references: [id], onDelete: Cascade)
  title            String
  kind             TestSectionKind
  selectionRule    Json? // e.g. { strategy: "ONE_PER_TOPIC", category, difficultyMix, verifiedOnly }
  marksPerQuestion Float           @default(1)
  order            Int             @default(0)

  items TestSectionItem[]
}

// Fixed/pinned items in a section. Dynamic items come from selectionRule at attempt start.
model TestSectionItem {
  id              String              @id @default(uuid())
  sectionId       String
  section         TestSection         @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  questionId      String?
  question        AssessmentQuestion? @relation(fields: [questionId], references: [id])
  codingProblemId String?
  codingProblem   CodingProblem?      @relation(fields: [codingProblemId], references: [id])
  order           Int                 @default(0)
}

model TestAttempt {
  id              String         @id @default(uuid())
  testId          String
  test            AssessmentTest @relation(fields: [testId], references: [id])
  userId          String
  user            User           @relation(fields: [userId], references: [id])
  startedAt       DateTime       @default(now())
  submittedAt     DateTime?
  status          AttemptStatus  @default(IN_PROGRESS)
  durationUsedSec Int            @default(0)
  score           Float?
  breakdown       Json? // per-section / per-topic score breakdown
  itemsSnapshot   Json? // resolved ordered item list, frozen at attempt start
  consentAt       DateTime? // proctoring consent timestamp (required for PROCTORED)

  responses        AttemptResponse[]
  proctoringEvents ProctoringEvent[]

  @@index([testId, userId])
}

model AttemptResponse {
  id              String              @id @default(uuid())
  attemptId       String
  attempt         TestAttempt         @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  questionId      String?
  question        AssessmentQuestion? @relation(fields: [questionId], references: [id])
  codingProblemId String?
  codingProblem   CodingProblem?      @relation(fields: [codingProblemId], references: [id])
  answer          Json? // MCQ: chosen option id(s); coding: { language, code, lastRun }
  isCorrect       Boolean?
  marks           Float               @default(0)
  timeSpentSec    Int                 @default(0)
  flagged         Boolean             @default(false)
  updatedAt       DateTime            @updatedAt

  @@unique([attemptId, questionId])
  @@unique([attemptId, codingProblemId])
}

model ProctoringEvent {
  id          String              @id @default(uuid())
  attemptId   String
  attempt     TestAttempt         @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  type        ProctoringEventType
  meta        Json?
  snapshotUrl String?
  createdAt   DateTime            @default(now())

  @@index([attemptId, createdAt])
}

// Conversational AI interview — distinct from the InterviewCategory/InterviewTopic
// MCQ prep module above.
model AiInterview {
  id           String            @id @default(uuid())
  userId       String
  user         User              @relation(fields: [userId], references: [id])
  role         String // e.g. "SDE", "Backend"
  companyId    String?
  company      Company?          @relation(fields: [companyId], references: [id])
  status       AiInterviewStatus @default(IN_PROGRESS)
  startedAt    DateTime          @default(now())
  endedAt      DateTime?
  overallScore Float?
  rubricScores Json? // { technical, communication, structure, problemSolving, roleFit } 0–5 each
  summary      String?
  proctoringSummary Json? // face-presence event counts from the video interview — signal, not verdict

  turns AiInterviewTurn[]
}

model AiInterviewTurn {
  id          String              @id @default(uuid())
  interviewId String
  interview   AiInterview         @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  role        AiInterviewTurnRole
  content     String
  audioUrl    String?
  turnScore   Float?
  feedback    String?
  order       Int

  @@index([interviewId, order])
}
